[Unit]
Description=Straw Bale Records
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/pi/StrawApp
ExecStart=/usr/bin/python3 /home/pi/StrawApp/server.py --host 0.0.0.0 --port 8095
Restart=always
RestartSec=5
User=pi

[Install]
WantedBy=multi-user.target
